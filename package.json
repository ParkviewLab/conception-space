{
  "name": "conception-space",
  "version": "0.8.2",
  "description": "3D concept graph visualiser",
  "author": "Gary Frattarola <garyf@parkviewlab.ai>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParkviewLab/conception-space.git"
  },
  "homepage": "https://github.com/ParkviewLab/conception-space#readme",
  "bugs": {
    "url": "https://github.com/ParkviewLab/conception-space/issues"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint .",
    "legal:prepare": "node scripts/prepare-legal.mjs",
    "legal:notices": "generate-license-file --input ./package.json --output ./legal/THIRD-PARTY-NOTICES.txt --overwrite --eol lf --ci",
    "legal:list": "license-checker-rseidelsohn --production --json --out ./legal/oss-licenses.json && node scripts/clean-oss-licenses.mjs",
    "legal": "npm run legal:prepare && npm run legal:notices && npm run legal:list",
    "build:dist": "npm run legal && electron-vite build && electron-builder"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^34.3.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.5.0",
    "generate-license-file": "^4.2.1",
    "globals": "^17.6.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "json5": "^2.2.3",
    "katex": "^0.17.0",
    "marked": "^18.0.4",
    "marked-katex-extension": "^5.1.9",
    "three": "^0.170.0"
  },
  "overrides": {
    "yauzl": "^3.3.1"
  }
}
