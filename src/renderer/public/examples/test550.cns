# test550.cns — synthetic test scene, ~550 nodes
# Three spatial arrangements across 3+ levels of clusters:
#   • Sphere surface  (Fibonacci spiral)  — globular_cluster, nebula_cloud
#   • Planar / solar  (concentric rings)  — stellar_neighborhood
#   • Molecule-like   (helix, β-sheet, honeycomb) — protein_complex, crystal_lattice

cluster test_universe ( label="Test Universe" locus=[0,0,0] N=2 color=#06061a brightness=0.4 tube_thickness=1 ) {

  # ── Protein Complex  (helix + β-sheet + binding sphere)
